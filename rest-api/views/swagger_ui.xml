<odoo>
    <template id="swagger_ui" name="Swagger UI">
        <t t-call="web.layout">
            <div class="container">
                <link rel="stylesheet"
                      href="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.18.3/swagger-ui.css"/>

                <div id="swagger-ui"></div>

                <script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.18.3/swagger-ui-bundle.js"></script>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.18.3/swagger-ui-standalone-preset.js"></script>

                <script>
                    window.onload = function() {
                        SwaggerUIBundle({
                            url: window.location.origin + '/swagger.json',
                            dom_id: '#swagger-ui',
                            presets: [
                                SwaggerUIBundle.presets.apis,
                                SwaggerUIStandalonePreset
                            ],
                            layout: "StandaloneLayout"
                        });
                    };
                </script>
            </div>
        </t>
    </template>

    <record id="action_swagger_ui" model="ir.actions.act_url">
        <field name="name">Swagger UI</field>
        <field name="url">/swagger_ui_page</field>
        <field name="target">self</field>
    </record>
</odoo>